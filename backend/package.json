{
  "name": "wallpaper-sync-backend",
  "version": "1.0.0",
  "description": "Cloudflare Workers backend for wallpaper sync ecosystem",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:init": "wrangler d1 execute wallpaper-sync-db --file=src/db/schema.sql",
    "db:init:local": "wrangler d1 execute wallpaper-sync-db --local --file=src/db/schema.sql"
  },
  "dependencies": {
    "itty-router": "^5.0.17",
    "jose": "^5.6.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20241127.0",
    "typescript": "^5.6.3",
    "wrangler": "^3.91.0"
  }
}
